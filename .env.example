# Google Cloud Console -> APIs & Services -> Credentials -> OAuth client ID
# (Application type: Web application). Enable the Calendar API and Gmail API
# for the project, and add your dev/deploy origins as authorised JavaScript
# origins (e.g. http://localhost:5173 and your GitHub Pages URL).
VITE_GOOGLE_CLIENT_ID=

# Spotify Developer Dashboard (developer.spotify.com/dashboard) -> your app ->
# Settings. Add redirect URIs matching this app's dev/deploy URLs exactly,
# including the trailing slash (see README). Only the Client ID goes here —
# never the Client Secret, this app uses Authorization Code + PKCE precisely
# so it doesn't need one.
VITE_SPOTIFY_CLIENT_ID=

# The Guardian Open Platform (open-platform.theguardian.com) -> register for
# a free developer key (personal/non-commercial use). Simple API key in the
# query string, no OAuth — same shape as the Weather widget.
VITE_GUARDIAN_API_KEY=

# Reading Buses Open Data (reading-opendata.r2p.com/api-service) -> register
# for a free API key. Query-string token, no OAuth.
VITE_READING_BUSES_API_KEY=

# Approximate home coordinates, used to sort bus stops by distance. Only
# needs to be accurate to a few decimal places (~100m).
VITE_HOME_LAT=
VITE_HOME_LON=
